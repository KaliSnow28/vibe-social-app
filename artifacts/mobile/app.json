{
  "expo": {
    "name": "Vibe",
    "slug": "vibe-social-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vibeapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vibesocial.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Vibe needs camera access to let you take photos and videos for posts and stories.",
        "NSMicrophoneUsageDescription": "Vibe needs microphone access for video recording and live streaming.",
        "NSPhotoLibraryUsageDescription": "Vibe needs photo library access to let you share photos and videos.",
        "NSLocationWhenInUseUsageDescription": "Vibe uses your location to let you tag posts with your location.",
        "NSFaceIDUsageDescription": "Vibe uses Face ID to keep your account secure."
      }
    },
    "android": {
      "package": "com.vibesocial.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-camera",
      "expo-media-library"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "vibe-social-app"
      }
    }
  }
}
